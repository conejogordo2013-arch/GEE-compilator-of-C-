#include "../../stdlib/memory.h"

extern int32 puts(string);

#include "../../jccsc/jccsc.cb"

int32 main() {
    string src = "global using Core = System.Collections; using IO = System.IO; using Demo.Tools; namespace Company.Product.Module { record Pair(int A, int B); interface IWorker { int Run(); } class Program { class Nested { public static int Seed() { return 7; } } public static async int Main() { const int N = 3; var total = 0; dynamic dyn = 1; int? maybe = 0; Func<int,int> fn = x => x + 1; int[,] grid = new int[2,2]; int[] arr = new int[N]; int i = 0; do { arr[i] = i + Nested.Seed(); i = i + 1; } while (i < N); for (i = 0; i < N; i = i + 1) { total = total + arr[i]; } var q = arr where i > 0 select i; switch (total) { case 24: break; default: total = total > 0 ? total : 1; break; } try { await dyn; return fn(total); } catch { return 1; } } } }";

    int64 mem = alloc(12288);
    if (mem == 0) return 2;

    byte* out = mem;
    struct JccscLexResult lex;
    struct JccscAst ast;
    struct JccscIr ir;
    struct JccscCompileCache cache;
    struct JccscBuildStats stats;
    struct JccscDiagnosticEngine diag;
    struct JccscDebugSession dbg;
    int64 rep_mem = alloc(8192);
    if (rep_mem == 0) { free(mem); return 9; }
    byte* rep = rep_mem;
    int64 trace_mem = alloc(8192);
    int64 ast_mem = alloc(4096);
    int64 ir_mem = alloc(4096);
    if (trace_mem == 0 || ast_mem == 0 || ir_mem == 0) { free(rep_mem); free(mem); return 11; }

    jccsc_cache_init(&cache);
    int32 ok = jccsc_compile_incremental(src, out, 12288, &cache, &stats, &lex, &ast, &ir);
    if (ok == 0) { free(mem); return 3; }

    if (lex.has_using == 0 || lex.has_using_alias == 0 || lex.has_global_using == 0) {
        free(mem);
        return 4;
    }

    if (lex.has_namespace_dotted == 0 || lex.has_nested_class == 0 || lex.has_var == 0 || lex.has_multidim_array == 0) {
        free(mem);
        return 5;
    }

    if (ast.namespace_depth_max < 3 || ast.using_alias_count == 0 || ast.nested_class_count == 0 || ast.var_infer_count == 0) {
        free(mem);
        return 6;
    }

    if (ir.namespace_count == 0 || ir.using_alias_count == 0 || ir.nested_count == 0 || ir.chain_count == 0 || ir.modern_feature_count == 0) {
        free(mem);
        return 7;
    }

    ok = jccsc_compile_incremental(src, out, 12288, &cache, &stats, &lex, &ast, &ir);
    if (ok == 0 || stats.cache_hit == 0 || stats.backend_ran == 0) {
        free(rep_mem);
        free(mem);
        return 8;
    }

    jccsc_diag_init(&diag, rep, 8192, 1);
    string bad = "class Program { int Main() { var broken; return 0; } }";
    ok = jccsc_compile_with_diagnostics(bad, out, 12288, &diag, &lex, &ast, &ir);
    if (ok != 0 || diag.error_count == 0 || diag.last_code == 0) {
        free(trace_mem);
        free(ast_mem);
        free(ir_mem);
        free(rep_mem);
        free(mem);
        return 10;
    }

    jccsc_debug_enable(&dbg, trace_mem, 8192, 2);
    jccsc_debug_set_breakpoint(&dbg, 3, 0, 0);
    ok = jccsc_compile_debug(src, out, 12288, &dbg, &lex, &ast, &ir);
    if (ok != 2 || dbg.paused == 0) {
        free(trace_mem);
        free(ast_mem);
        free(ir_mem);
        free(rep_mem);
        free(mem);
        return 12;
    }
    jccsc_debug_dump_ast_text(&ast, ast_mem, 4096);
    jccsc_debug_dump_ir(&ir, ir_mem, 4096);

    puts(out);
    puts(rep);
    puts(trace_mem);
    puts(ast_mem);
    puts(ir_mem);
    free(trace_mem);
    free(ast_mem);
    free(ir_mem);
    free(rep_mem);
    free(mem);
    return 0;
}
